# Copy this file to ".env" and fill it in. The real .env is never committed
# (it holds our passwords). Nothing here is baked into the Docker image.
#
#   cp .env.example .env
#   nano .env

# --- The two accounts (OPTIONAL — normally leave empty) ---------------------
# Leave all of these empty: the app asks you to create both accounts the first
# time you open it in the browser. Only fill them in if you want to force the
# accounts from here — e.g. to RESET A FORGOTTEN PASSWORD (set all four, restart
# the container once, then you may empty them again).
HEARTH_USER1=
HEARTH_PASS1=
HEARTH_NAME1=

HEARTH_USER2=
HEARTH_PASS2=
HEARTH_NAME2=

# --- Networking (LAN-only) -------------------------------------------------
# Set this to THIS machine's LAN IP so phones/PCs on the home wifi can reach it.
# Find it with:  hostname -I   (or:  ip addr | grep 192.168)
# Leaving it at 127.0.0.1 means only this machine can open the app.
HEARTH_BIND_IP=192.168.1.50

# Host port to expose (the in-container port is always 3000).
HEARTH_PORT=3000

# --- Local weather (optional) ----------------------------------------------
# The garden mirrors your real weather (clouds, rain, snow, sunrise/sunset) and
# shows a small weather card. Location is detected AUTOMATICALLY from your
# internet connection (city-level) — normally leave all three empty.
# Set coordinates only to override, e.g. if a VPN on this machine makes the
# auto-detected city wrong (search "<your city> coordinates" to find them).
# HEARTH_PLACE overrides the name shown on the card (e.g. "Our Home").
# Weather comes from open-meteo.com (free, no account), at most every 15 min.
HEARTH_LAT=
HEARTH_LON=
HEARTH_PLACE=

# --- Local time ------------------------------------------------------------
# Used for daily streaks / seasons. Example: America/New_York, Europe/London,
# Asia/Shanghai. See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# --- File ownership --------------------------------------------------------
# The container runs as this uid/gid so files in ./data belong to you. Most
# single-user Ubuntu machines are 1000/1000. Check with:  id -u ; id -g
HEARTH_UID=1000
HEARTH_GID=1000
